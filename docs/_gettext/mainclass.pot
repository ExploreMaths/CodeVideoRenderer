#: ../mainclass.rst:2
msgid "CameraFollowCursorCV"
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:1
msgid "CameraFollowCursorCV is a class designed to create animated videos that simulate the process of typing code. It animates code line by line and character by character while smoothly moving the camera to follow the cursor, creating a professional-looking coding demonstration."
msgstr ""

#: ../mainclass.rst:0
msgid "Parameters"
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:4
msgid "The code to be animated. **When using a string**, provide a tuple with the first element as ``'string'`` and the second element as the code string. **When using a file**, provide a tuple with the first element as ``'file'`` and the second element as the file path."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:6
msgid "The programming language of the code."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:8
msgid "The style for syntax highlighting. Defaults to ``\"material\"``."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:10
msgid "The line spacing for the code. Defaults to :data:`~.DEFAULT_LINE_SPACING`."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:12
msgid "The range of typing intervals between characters. Defaults to (:data:`~.DEFAULT_TYPE_INTERVAL`, :data:`~.DEFAULT_TYPE_INTERVAL`)."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:14
msgid "The scale factor for the camera. Defaults to 0.5."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:16
msgid "The name of the output video file. Defaults to ``\"CameraFollowCursorCV\"``."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV:18
msgid "The renderer to use for video rendering. Defaults to ``'cairo'``."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV._create_scene:1
msgid "Create manim scene to animate code rendering."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV.render:1
msgid "Render the scene, optionally with console output."
msgstr ""

#: ../../CodeVideoRenderer/renderer.py:docstring of CodeVideoRenderer.renderer.CameraFollowCursorCV.render:3
msgid "Whether to print console output during rendering. Defaults to :data:`~.DEFAULT_OUTPUT_VALUE`."
msgstr ""

